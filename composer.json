{
  "name": "screenshotcenter/screenshotcenter",
  "description": "PHP SDK for the ScreenshotCenter API",
  "type": "library",
  "license": "MIT",
  "keywords": ["screenshot", "api", "web", "automation", "pdf"],
  "homepage": "https://screenshotcenter.com",
  "authors": [
    {
      "name": "ScreenshotCenter",
      "email": "support@screenshotcenter.com",
      "homepage": "https://screenshotcenter.com"
    }
  ],
  "require": {
    "php": ">=7.2",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "ScreenshotCenter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ScreenshotCenter\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
